# Copy to .env and adjust. Defaults match infra/docker/docker-compose.yml.

NODE_ENV=development

# Postgres
DATABASE_URL=postgresql://migrationtower:migrationtower@localhost:5432/migrationtower

# Redis (BullMQ)
REDIS_URL=redis://localhost:6379

# Object storage (MinIO, S3-compatible)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=migrationtower
S3_SECRET_ACCESS_KEY=migrationtower
S3_BUCKET=migration-tower
S3_FORCE_PATH_STYLE=true

# SMTP (Mailhog) — view sent mail at http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
MAIL_FROM="Migration Tower <no-reply@migration-tower.dev>"

# API
API_PORT=4000
