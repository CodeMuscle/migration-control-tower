{
  "name": "@migrationtower/services-common",
  "version": "0.0.0",
  "private": true,
  "description": "Shared BullMQ patterns for services (worker base, queue config, Redis connection).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"@migrationtower/services-common: no tests yet\"",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@migrationtower/contracts": "workspace:*",
    "bullmq": "^5.13.2",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@migrationtower/tsconfig": "workspace:*",
    "@types/node": "20",
    "typescript": "^5.4.5"
  }
}
