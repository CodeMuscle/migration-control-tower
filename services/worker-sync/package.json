{
  "name": "@migrationtower/worker-sync",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ worker: ongoing source<->destination sync jobs (idempotent).",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"@migrationtower/worker-sync: no tests yet\"",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "devDependencies": {
    "@migrationtower/tsconfig": "workspace:*",
    "@types/node": "20",
    "typescript": "^5.4.5"
  }
}
