{
  "name": "@migrationtower/api",
  "version": "0.0.0",
  "private": true,
  "description": "Main HTTP API (NestJS 10 + Fastify). Every endpoint returns the common envelope; tenant resolved by the global AuthGuard.",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
    "build": "nest build",
    "dev": "nest start --watch",
    "start": "node dist/main.js",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "@clerk/backend": "^1.21.0",
    "@migrationtower/contracts": "workspace:*",
    "@migrationtower/db": "workspace:*",
    "@nestjs/common": "^10.4.4",
    "@nestjs/core": "^10.4.4",
    "@nestjs/platform-fastify": "^10.4.4",
    "@opentelemetry/auto-instrumentations-node": "^0.52.0",
    "@opentelemetry/sdk-node": "^0.54.0",
    "@opentelemetry/sdk-trace-base": "^1.27.0",
    "dotenv": "^16.4.5",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.4.0",
    "pino-http": "^10.3.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@migrationtower/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/schematics": "^10.1.4",
    "@testcontainers/postgresql": "^10.13.2",
    "@types/node": "20",
    "pino-pretty": "^11.2.2",
    "typescript": "^5.4.5",
    "vitest": "^2.1.4"
  }
}
