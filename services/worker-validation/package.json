    "@opentelemetry/sdk-trace-base": "^1.27.0",
    "bullmq": "^5.13.2",
    "csv-parse": "^5.5.6",
    "dotenv": "^16.4.5",
    "nestjs-pino": "^4.1.0",
    "pino": "^9.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
