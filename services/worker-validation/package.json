{
  "name": "@migrationtower/worker-validation",
  "version": "0.0.0",
  "private": true,
  "description": "BullMQ worker service: upload parsing + schema inference (LLD §7, partial — parse/snapshot only for now).",
  "type": "module",
  "main": "./dist/main.js",
  "scripts": {
