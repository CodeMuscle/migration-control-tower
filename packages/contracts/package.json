{
  "name": "@migrationtower/contracts",
  "version": "0.0.0",
  "private": true,
  "description": "Canonical shared contracts: API envelope, tenant context, job descriptors. Source of truth for cross-package types.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint \"src/**/*.ts\" --max-warnings=0",
    "type-check": "tsc -p tsconfig.json --noEmit",
    "test": "echo \"@migrationtower/contracts: no tests yet\"",
    "clean": "rm -rf dist .turbo *.tsbuildinfo"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@migrationtower/tsconfig": "workspace:*",
    "typescript": "^5.4.5"
  }
}
