// Customer Migration Control Tower — database schema.
//
// Source of truth: /docs/design/database-blueprint.docx (Modules 1–6:
// Identity, Tenant, Migration Projects, Source Ingestion, Schema Registry,
// Mapping). Column names/types match the blueprint exactly.
//
// Conventions (CLAUDE.md):
//   - DB is snake_case (@map / @@map); the Prisma/TS surface is camelCase.
//   - Every business table carries tenant_id with a FK to tenants.
//   - UUID PKs (app-generated, @db.Uuid). TIMESTAMPTZ for time. JSONB for docs.
//   - Emails are CITEXT (citext extension created in the initial migration).
//
// multiSchema is enabled for future per-module schema separation; v1 keeps a
// single `public` schema (every model is @@schema("public")).

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["multiSchema"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]
}

// ───────────────────────────── Module 1 — Identity ─────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @unique @db.Citext
  fullName    String    @map("full_name") @db.VarChar(150)
  avatarUrl   String?   @map("avatar_url") @db.Text
  status      String    @db.VarChar(20) // active, invited, disabled
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships        Membership[]            @relation("MembershipUser")
  membershipsInvited Membership[]            @relation("MembershipInvitedBy")
  invitationsSent    Invitation[]            @relation("InvitationInvitedBy")
  projectsOwned      MigrationProject[]      @relation("ProjectOwner")
  stageChanges       MigrationStageHistory[] @relation("StageChangedBy")
  projectMemberships ProjectMember[]         @relation("ProjectMemberUser")
  activities         ProjectActivity[]       @relation("ActivityActor")
  uploads            SourceUpload[]          @relation("UploadUploadedBy")
  mappingVersionsPub MappingVersion[]        @relation("MappingVersionPublishedBy")

  @@map("users")
  @@schema("public")
}

model Membership {
  id        String    @id @default(uuid()) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  role      String    @db.VarChar(40) // owner, admin, manager, engineer, customer_viewer, customer_editor
  status    String    @db.VarChar(20) // active, invited, revoked
  invitedBy String?   @map("invited_by") @db.Uuid
  joinedAt  DateTime? @map("joined_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user          User   @relation("MembershipUser", fields: [userId], references: [id], onDelete: Restrict)
  invitedByUser User?  @relation("MembershipInvitedBy", fields: [invitedBy], references: [id], onDelete: SetNull)

  @@unique([tenantId, userId])
  @@index([tenantId, role])
  @@map("memberships")
  @@schema("public")
}

model Invitation {
  id         String    @id @default(uuid()) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  email      String    @db.Citext
  role       String    @db.VarChar(40)
  tokenHash  String    @map("token_hash") @db.Text
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  acceptedAt DateTime? @map("accepted_at") @db.Timestamptz(6)
  invitedBy  String    @map("invited_by") @db.Uuid
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  invitedByUser User   @relation("InvitationInvitedBy", fields: [invitedBy], references: [id], onDelete: Restrict)

  @@index([tenantId, email])
  @@map("invitations")
  @@schema("public")
}

// ───────────────────────────── Module 2 — Tenant ──────────────────────────────

model Tenant {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(150)
  slug          String   @unique @db.VarChar(80)
  plan          String   @db.VarChar(40) // free, growth, enterprise
  status        String   @db.VarChar(20) // active, suspended, trialing
  primaryRegion String   @map("primary_region") @db.VarChar(20)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  memberships         Membership[]
  invitations         Invitation[]
  settings            TenantSettings[]
  featureEntitlements FeatureEntitlement[]
  projects            MigrationProject[]
  stageHistory        MigrationStageHistory[]
  projectMembers      ProjectMember[]
  projectActivity     ProjectActivity[]
  dataSources         DataSource[]
  sourceUploads       SourceUpload[]
  sourceBatches       SourceBatch[]
  destinationSchemas  DestinationSchema[]
  sourceSnapshots     SourceSchemaSnapshot[]
  schemaFields        SchemaField[]
  fieldMappings       FieldMapping[]
  transformRules      TransformRule[]
  mappingVersions     MappingVersion[]
  mappingTemplates    MappingTemplate[]
  idempotencyKeys     IdempotencyKey[]

  @@map("tenants")
  @@schema("public")
}

// Idempotency replay store for mutating workflows (e.g. uploads/presign).
// (tenant_id, idempotency_key) -> the original response; honoured until
// expires_at (24h) then ignored/swept. Not one of the blueprint's six
// modules — a cross-cutting Module-4 support table.
model IdempotencyKey {
  id             String   @id @default(uuid()) @db.Uuid
  tenantId       String   @map("tenant_id") @db.Uuid
  idempotencyKey String   @map("idempotency_key") @db.Text
  endpoint       String   @db.VarChar(120)
  response       Json     @db.JsonB
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  expiresAt      DateTime @map("expires_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, idempotencyKey])
  @@index([expiresAt])
  @@map("idempotency_keys")
  @@schema("public")
}

model TenantSettings {
  id                    String   @id @default(uuid()) @db.Uuid
  tenantId              String   @map("tenant_id") @db.Uuid
  defaultTimezone       String   @map("default_timezone") @db.VarChar(50)
  dataRetentionDays     Int      @map("data_retention_days")
  defaultProductType    String   @map("default_product_type") @db.VarChar(50)
  allowCustomerComments Boolean  @map("allow_customer_comments")
  piiMaskingEnabled     Boolean  @map("pii_masking_enabled")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId])
  @@map("tenant_settings")
  @@schema("public")
}

model FeatureEntitlement {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  featureKey String   @map("feature_key") @db.VarChar(80)
  enabled    Boolean
  config     Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, featureKey])
  @@map("feature_entitlements")
  @@schema("public")
}

// ──────────────────────── Module 3 — Migration Projects ───────────────────────

model MigrationProject {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  name              String    @db.VarChar(150)
  customerName      String    @map("customer_name") @db.VarChar(150)
  projectCode       String    @map("project_code") @db.VarChar(50)
  status            String    @db.VarChar(30) // draft, active, blocked, ready_for_cutover, completed, rolled_back
  currentStage      String    @map("current_stage") @db.VarChar(40) // setup, ingestion, mapping, validation, dry_run, cutover, complete
  migrationType     String    @map("migration_type") @db.VarChar(30) // file, api, hybrid
  targetEnvironment String    @map("target_environment") @db.VarChar(20) // sandbox, production
  targetProductType String    @map("target_product_type") @db.VarChar(50)
  ownerUserId       String    @map("owner_user_id") @db.Uuid
  dueAt             DateTime? @map("due_at") @db.Timestamptz(6)
  wentLiveAt        DateTime? @map("went_live_at") @db.Timestamptz(6)
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant       Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  owner        User                    @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: Restrict)
  stageHistory MigrationStageHistory[]
  members      ProjectMember[]
  activity     ProjectActivity[]
  dataSources  DataSource[]

  @@unique([tenantId, projectCode])
  @@index([tenantId, status])
  @@index([tenantId, currentStage])
  @@map("migration_projects")
  @@schema("public")
}

model MigrationStageHistory {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  projectId String   @map("project_id") @db.Uuid
  fromStage String?  @map("from_stage") @db.VarChar(40)
  toStage   String   @map("to_stage") @db.VarChar(40)
  changedBy String   @map("changed_by") @db.Uuid
  reason    String?  @db.Text
  changedAt DateTime @default(now()) @map("changed_at") @db.Timestamptz(6)

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project       MigrationProject @relation(fields: [projectId], references: [id], onDelete: Restrict)
  changedByUser User             @relation("StageChangedBy", fields: [changedBy], references: [id], onDelete: Restrict)

  @@index([tenantId, projectId])
  @@map("migration_stage_history")
  @@schema("public")
}

model ProjectMember {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  projectId   String   @map("project_id") @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  accessLevel String   @map("access_level") @db.VarChar(30) // owner, editor, viewer
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project MigrationProject @relation(fields: [projectId], references: [id], onDelete: Restrict)
  user    User             @relation("ProjectMemberUser", fields: [userId], references: [id], onDelete: Restrict)

  @@unique([tenantId, projectId, userId])
  @@map("project_members")
  @@schema("public")
}

model ProjectActivity {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @map("tenant_id") @db.Uuid
  projectId    String   @map("project_id") @db.Uuid
  actorUserId  String?  @map("actor_user_id") @db.Uuid
  activityType String   @map("activity_type") @db.VarChar(60)
  payload      Json     @db.JsonB
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project MigrationProject @relation(fields: [projectId], references: [id], onDelete: Restrict)
  actor   User?            @relation("ActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId])
  @@map("project_activity")
  @@schema("public")
}

// ──────────────────────── Module 4 — Source Ingestion ─────────────────────────

model DataSource {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @map("tenant_id") @db.Uuid
  projectId          String   @map("project_id") @db.Uuid
  sourceType         String   @map("source_type") @db.VarChar(30) // csv, xlsx, api, s3, manual
  name               String   @db.VarChar(120)
  externalSystemName String?  @map("external_system_name") @db.VarChar(120)
  status             String   @db.VarChar(30) // connected, uploaded, processing, ready, failed
  connectionConfig   Json?    @map("connection_config") @db.JsonB
  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant  Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  project MigrationProject @relation(fields: [projectId], references: [id], onDelete: Restrict)
  uploads SourceUpload[]
  batches SourceBatch[]

  @@index([tenantId, projectId])
  @@map("data_sources")
  @@schema("public")
}

model SourceUpload {
  id               String    @id @default(uuid()) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  projectId        String    @map("project_id") @db.Uuid
  dataSourceId     String    @map("data_source_id") @db.Uuid
  objectKey        String    @map("object_key") @db.Text
  originalFilename String    @map("original_filename") @db.VarChar(255)
  mimeType         String    @map("mime_type") @db.VarChar(100)
  sizeBytes        BigInt    @map("size_bytes")
  checksumSha256   String    @map("checksum_sha256") @db.Text
  uploadStatus     String    @map("upload_status") @db.VarChar(20) // pending, uploaded, processing, processed, failed
  uploadedBy       String    @map("uploaded_by") @db.Uuid
  uploadedAt       DateTime? @map("uploaded_at") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  dataSource     DataSource    @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)
  uploadedByUser User          @relation("UploadUploadedBy", fields: [uploadedBy], references: [id], onDelete: Restrict)
  batches        SourceBatch[]

  @@index([tenantId, projectId])
  @@map("source_uploads")
  @@schema("public")
}

model SourceBatch {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  projectId      String    @map("project_id") @db.Uuid
  dataSourceId   String    @map("data_source_id") @db.Uuid
  sourceUploadId String?   @map("source_upload_id") @db.Uuid
  batchType      String    @map("batch_type") @db.VarChar(20) // initial, retry, delta
  status         String    @db.VarChar(20) // queued, parsing, parsed, validation_pending, failed
  rowCount       Int?      @map("row_count")
  startedAt      DateTime? @map("started_at") @db.Timestamptz(6)
  finishedAt     DateTime? @map("finished_at") @db.Timestamptz(6)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant       Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  dataSource   DataSource             @relation(fields: [dataSourceId], references: [id], onDelete: Restrict)
  sourceUpload SourceUpload?          @relation(fields: [sourceUploadId], references: [id], onDelete: SetNull)
  snapshots    SourceSchemaSnapshot[]

  @@index([tenantId, projectId])
  @@map("source_batches")
  @@schema("public")
}

// ──────────────────────── Module 5 — Schema Registry ──────────────────────────

model DestinationSchema {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String?  @map("tenant_id") @db.Uuid // nullable: global default schemas
  productType String   @map("product_type") @db.VarChar(50)
  version     String   @db.VarChar(40)
  status      String   @db.VarChar(20) // active, deprecated
  schemaJson  Json     @map("schema_json") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant        Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  fieldMappings FieldMapping[]

  @@unique([tenantId, productType, version])
  @@map("destination_schemas")
  @@schema("public")
}

model SourceSchemaSnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String   @map("tenant_id") @db.Uuid
  projectId         String   @map("project_id") @db.Uuid
  batchId           String   @map("batch_id") @db.Uuid
  version           Int // monotonic per project
  detectedFormat    String   @map("detected_format") @db.VarChar(20) // csv, xlsx, json
  headerRowIndex    Int      @map("header_row_index")
  rowSampleCount    Int      @map("row_sample_count")
  schemaJson        Json     @map("schema_json") @db.JsonB
  detectionWarnings Json?    @map("detection_warnings") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  batch         SourceBatch    @relation(fields: [batchId], references: [id], onDelete: Restrict)
  fieldMappings FieldMapping[]

  @@index([tenantId, projectId])
  @@map("source_schema_snapshots")
  @@schema("public")
}

model SchemaField {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  schemaSnapshotId    String?  @map("schema_snapshot_id") @db.Uuid // nullable for destination
  destinationSchemaId String?  @map("destination_schema_id") @db.Uuid // nullable for source snapshots
  fieldKey            String   @map("field_key") @db.VarChar(100)
  displayName         String   @map("display_name") @db.VarChar(120)
  dataType            String   @map("data_type") @db.VarChar(30) // string, number, date, enum, boolean
  isRequired          Boolean  @map("is_required")
  enumValues          Json?    @map("enum_values") @db.JsonB
  metadata            Json?    @db.JsonB
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, schemaSnapshotId])
  @@index([tenantId, destinationSchemaId])
  @@map("schema_fields")
  @@schema("public")
}

// ───────────────────────────── Module 6 — Mapping ─────────────────────────────

model FieldMapping {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  sourceSnapshotId    String   @map("source_snapshot_id") @db.Uuid
  destinationSchemaId String   @map("destination_schema_id") @db.Uuid
  sourceFieldKey      String?  @map("source_field_key") @db.VarChar(100)
  destinationFieldKey String   @map("destination_field_key") @db.VarChar(100)
  mappingType         String   @map("mapping_type") @db.VarChar(30) // direct, constant, transform, composite, ignored
  transformRuleId     String?  @map("transform_rule_id") @db.Uuid
  defaultValue        Json?    @map("default_value") @db.JsonB
  config              Json?    @db.JsonB
  isRequiredOverride  Boolean? @map("is_required_override")
  status              String   @db.VarChar(20) // draft, active
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant            Tenant               @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  sourceSnapshot    SourceSchemaSnapshot @relation(fields: [sourceSnapshotId], references: [id], onDelete: Restrict)
  destinationSchema DestinationSchema    @relation(fields: [destinationSchemaId], references: [id], onDelete: Restrict)
  transformRule     TransformRule?       @relation(fields: [transformRuleId], references: [id], onDelete: SetNull)

  @@index([tenantId, projectId])
  @@index([tenantId, projectId, destinationFieldKey])
  @@map("field_mappings")
  @@schema("public")
}

model TransformRule {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  projectId   String?  @map("project_id") @db.Uuid // nullable for reusable rules
  ruleKey     String   @map("rule_key") @db.VarChar(80) // trim, uppercase, concat, date_parse, phone_normalize
  displayName String   @map("display_name") @db.VarChar(120)
  ruleConfig  Json     @map("rule_config") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant   Tenant         @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  mappings FieldMapping[]

  @@index([tenantId, projectId])
  @@map("transform_rules")
  @@schema("public")
}

model MappingVersion {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @map("tenant_id") @db.Uuid
  projectId           String   @map("project_id") @db.Uuid
  sourceSnapshotId    String   @map("source_snapshot_id") @db.Uuid
  destinationSchemaId String   @map("destination_schema_id") @db.Uuid
  versionNumber       Int      @map("version_number") // monotonic per project
  status              String   @db.VarChar(20) // published, deprecated
  mappingJson         Json     @map("mapping_json") @db.JsonB
  publishedBy         String   @map("published_by") @db.Uuid
  publishedAt         DateTime @map("published_at") @db.Timestamptz(6)
  notes               String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  tenant          Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  publishedByUser User   @relation("MappingVersionPublishedBy", fields: [publishedBy], references: [id], onDelete: Restrict)

  @@unique([tenantId, projectId, versionNumber])
  @@index([tenantId, projectId])
  @@map("mapping_versions")
  @@schema("public")
}

model MappingTemplate {
  id                String   @id @default(uuid()) @db.Uuid
  tenantId          String?  @map("tenant_id") @db.Uuid // nullable for global templates
  templateName      String   @map("template_name") @db.VarChar(120)
  sourceSystemName  String   @map("source_system_name") @db.VarChar(120)
  targetProductType String   @map("target_product_type") @db.VarChar(50)
  templateJson      Json     @map("template_json") @db.JsonB
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([tenantId, targetProductType])
  @@map("mapping_templates")
  @@schema("public")
}
